{
    "categories": [
        {
            "title": "✨ Features",
            "labels": [
                "feature",
                "feat"
            ]
        },
        {
            "title": "🐛 Bug Fixes",
            "labels": [
                "fix",
                "bug"
            ]
        },
        {
            "title": "📦 Dependencies",
            "labels": [
                "dependency"
            ]
        },
        {
            "title": "🔧 Maintenance & CI",
            "labels": [
                "chore",
                "ci"
            ]
        },
        {
            "title": "📝 Documentation",
            "labels": [
                "docs"
            ]
        },
        {
            "title": "🧪 Tests",
            "labels": [
                "test"
            ]
        },
        {
            "title": "Other Changes",
            "labels": []
        }
    ],
    "ignore_labels": [
        "ignore",
        "no-changelog"
    ],
    "sort": "DESC",
    "template": "⚠️ **IMPORTANT**: This integration requires the corresponding Home Assistant App to be updated. Please ensure you are running the latest version of the [WhatsApp HA App (Add-on)](https://github.com/FaserF/hassio-addons/tree/master/whatsapp).\n\n# Changelog\n\n#{{CHANGELOG}}\n",
    "pr_template": "- #{{PR_TITLE}} ##{{PR_NUMBER}}",
    "commit_template": "- #{{SUMMARY}}",
    "empty_template": "No significant changes in this release.",
    "label_extractor": [
        {
            "pattern": ".*\\[skip ci\\].*",
            "target": "ignore",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(chore: release|chore: bump|chore: auto-fix|ci fix|update release)\\b",
            "target": "ignore",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(merge pull request|merge branch)\\b",
            "target": "ignore",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(feat|feature|add)\\b",
            "target": "✨ Features",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(fix|bug|patch|fixed|fixes)\\b",
            "target": "🐛 Bug Fixes",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(deps|dependenc|update)\\b",
            "target": "📦 Dependencies",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(docs|documentation)\\b",
            "target": "📝 Documentation",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(test|pytest)\\b",
            "target": "🧪 Tests",
            "flags": "i",
            "on_property": "message"
        },
        {
            "pattern": "\\b(chore|config|ci|workflow|ruff)\\b",
            "target": "🔧 Maintenance & CI",
            "flags": "i",
            "on_property": "message"
        }
    ],
    "duplicate_filter": {
        "pattern": ".*",
        "on_property": "message"
    },
    "base_branches": [
        "main"
    ]
}
